# Copy to .env and tweak. docker compose reads .env automatically.

# Host ports (change if 8080/8081/3307 are taken)
WEB_PORT=8080
ADMINER_PORT=8081
DB_PORT=3307

# DB credentials baked into the MySQL container.
# Override here AND in docker-compose.yml's `db.environment` block if you
# change them — the init scripts run only on first boot.
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_USER=warcry
MYSQL_PASSWORD=warcry

# CMS-side overrides. The container already injects these via compose; only
# uncomment if you run a host-side PHP and want it to talk to the same DB.
# WARCRY_DB_HOST=127.0.0.1
# WARCRY_DB_USER=warcry
# WARCRY_DB_PASS=warcry
# WARCRY_DB_NAME=warcry
# WARCRY_AUTH_HOST=127.0.0.1
# WARCRY_AUTH_USER=warcry
# WARCRY_AUTH_PASS=warcry
# WARCRY_AUTH_NAME=auth
# WARCRY_BASE_URL=http://localhost:8080
